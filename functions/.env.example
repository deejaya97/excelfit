# Copy this file to .env and fill in your values
# NEVER commit .env — it is listed in .gitignore

# Neon DB connection string (from neon.tech dashboard)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Staff login credentials (used to authenticate in the app)
STAFF_EMAIL=admin@yourgym.com
STAFF_PASSWORD=change-this-to-a-strong-password

# Random secret for signing session tokens (generate with: openssl rand -hex 32)
SESSION_SECRET=replace-with-a-long-random-string

# (Optional) Allowed CORS origin in production — set to your Render frontend URL
# CORS_ORIGIN=https://excelfit-web.onrender.com
